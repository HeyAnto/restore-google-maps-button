{
  "manifest_version": 3,
  "name": "Restore Maps Button",
  "version": "1.0.0",
  "description": "Restores the Maps button on Google search results pages.",
  "permissions": [],
  "action": {
    "default_popup": "ui/popup.html",
    "default_title": "Restore Maps Button"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "include_globs": ["*://www.google.*/search*"],
      "js": ["scripts/content.js"],
      "run_at": "document_start"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "google-maps-button-restorer@example.com",
      "strict_min_version": "110.0"
    }
  }
}
